# .npmrc - Enterprise CI/CD Configuration

# 1. Retry logic for transient network failures (mitigates corrupted downloads)
fetch-retries=5
fetch-retry-factor=2
fetch-retry-maxtimeout=120000
fetch-retry-mintimeout=10000

# 2. Reduce npm logs
loglevel=warn

# 3. Platform-specific cache (set in environment, not hardcoded)
# In Vercel: cache=/vercel/.npm
# In local: os.tmpdir() is used automatically
