# .npmrc - Stabilized for Windows development + CI compatibility

# 1. Retry logic for transient network failures
fetch-retries=5
fetch-retry-factor=2
fetch-retry-maxtimeout=120000
fetch-retry-mintimeout=10000

# 2. Reduce npm logs
loglevel=warn

# 3. Disable audit/fund noise in dev
audit-level=moderate
fund=false

# 4. Use deterministic installs
package-lock=true
